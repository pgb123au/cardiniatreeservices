---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Thanks &mdash; we&rsquo;ll be in touch | Cardinia Tree Services"
  description="Your tree services quote request has been received. We'll be in touch within 1 business day."
  canonical="https://cardiniatreeservices.com.au/thanks/">
  <Fragment slot="head">
    <meta name="robots" content="noindex, follow">
  </Fragment>


  <section class="hero" style="padding: 4rem 0;">
    <div class="hero-inner">
      <span class="hero-eyebrow">Got it</span>
      <h1>Thanks &mdash; we&rsquo;ve got your details.</h1>
      <p class="hero-sub">
        We&rsquo;ll review your enquiry and call you back within 1 business day
        to arrange a free on-site assessment. If your job is urgent &mdash;
        tree on a house, car or driveway &mdash; please call the main number
        directly: <a href="tel:+61390030108" style="color:#E8A33D; text-decoration:underline;">(03) 9003 0108</a>. The duty arborist answers 24/7.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="tel:+61390030108">&#9742; Call now</a>
        <a class="btn btn-ghost" href="/">Back to home</a>
      </div>
    </div>
  </section>
</Layout>
