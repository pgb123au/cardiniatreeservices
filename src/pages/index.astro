    background: rgba(15, 23, 42, 0.92);
    color: rgba(255, 255, 255, 0.85);
    padding: 0.85rem 1.25rem;
    text-align: center;
    font-size: 0.95rem;
    margin: 0;
  }
</style>


  <section class="hero">
